{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/terms", "destination": "/terms-of-service", "permanent": true },
    { "source": "/privacy", "destination": "/privacy-policy", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
